/* ─────────────────────────────────────────
   UrbanIA — Styles
───────────────────────────────────────── */
:root {
  --ink:        #111009;
  --bg:         #f5f2ec;
  --card:       #ffffff;
  --warm:       #ede9e0;
  --border:     #ddd8cc;
  --muted:      #7c7568;
  --green:      #1a5c3a;
  --green-bg:   #edf7f1;
  --red:        #c0381a;
  --red-bg:     #fdf1ee;
  --amber:      #9a6200;
  --amber-bg:   #fdf6e8;
  --blue:       #1e4a8a;
  --blue-bg:    #eef3fc;
  --accent:     #c0381a;
  --r:          12px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Epilogue', sans-serif;
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
}

/* ── TOP BAR ── */
.topbar {
  background: var(--ink);
  height: 52px;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 300;
}

.logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.3rem;
  color: #f5f2ec;
  letter-spacing: -0.03em;
}
.logo b { color: var(--accent); }

.top-badge {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.72rem;
  color: rgba(245,242,236,.45);
  font-weight: 500;
}

.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #4caf78;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

/* ── HERO ── */
.hero {
  background: var(--ink);
  padding: 3rem 1.5rem 4.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 55px;
  background: var(--bg);
  clip-path: ellipse(55% 100% at 50% 100%);
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  background: rgba(192,56,26,.18);
  border: 1px solid rgba(192,56,26,.3);
  color: #f4a080;
  font-size: .7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .1em;
  padding: .3rem 1rem;
  border-radius: 100px;
  margin-bottom: 1.3rem;
}

.hero h1 {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(1.8rem, 4.5vw, 3rem);
  color: #f5f2ec;
  letter-spacing: -0.04em;
  line-height: 1.05;
  margin-bottom: .9rem;
}
.hero h1 em { font-style: normal; color: var(--accent); }

.hero p {
  font-size: .93rem;
  color: rgba(245,242,236,.48);
  max-width: 480px;
  margin: 0 auto 2.5rem;
  line-height: 1.7;
  font-weight: 300;
}

/* ── SEARCH BOX ── */
.search-container {
  max-width: 660px;
  margin: 0 auto;
  position: relative;
  z-index: 10;
}

.search-box {
  background: var(--card);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0,0,0,.28), 0 2px 8px rgba(0,0,0,.15);
  overflow: hidden;
}

.search-row {
  display: flex;
  align-items: center;
  gap: .6rem;
  padding: .65rem .65rem .65rem 1.1rem;
}

.search-sep {
  height: 1px;
  background: var(--border);
  margin: 0 1.1rem;
}

.s-icon { font-size: 1.05rem; flex-shrink: 0; }

.s-label {
  font-size: .71rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--muted);
  white-space: nowrap;
  flex-shrink: 0;
}

.s-input {
  flex: 1;
  border: none;
  outline: none;
  font-family: 'Epilogue', sans-serif;
  font-size: .93rem;
  color: var(--ink);
  background: none;
  min-width: 0;
}
.s-input::placeholder { color: var(--muted); }
.s-addr { font-size: .86rem; }

.search-btn {
  background: var(--accent);
  color: white;
  border: none;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .82rem;
  padding: .62rem 1.3rem;
  border-radius: 10px;
  cursor: pointer;
  transition: all .18s;
  white-space: nowrap;
  flex-shrink: 0;
}
.search-btn:hover:not(:disabled) { background: #a82e14; transform: translateY(-1px); }
.search-btn:disabled { background: var(--border); color: var(--muted); cursor: not-allowed; transform: none; }

/* ── SUGGESTIONS ── */
.suggestions {
  position: absolute;
  top: calc(100% + 6px);
  left: 0; right: 0;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: 0 8px 30px rgba(0,0,0,.12);
  display: none;
  z-index: 400;
  overflow: hidden;
}
.suggestions.open { display: block; }

.sug-item {
  display: flex;
  align-items: center;
  gap: .6rem;
  padding: .75rem 1.1rem;
  font-size: .85rem;
  cursor: pointer;
  border-bottom: 1px solid var(--border);
  transition: background .1s;
}
.sug-item:last-child { border-bottom: none; }
.sug-item:hover { background: var(--warm); }
.sug-main { font-weight: 500; }
.sug-sub  { font-size: .73rem; color: var(--muted); margin-top: .1rem; }

/* ── MAIN ── */
.main {
  max-width: 940px;
  margin: 0 auto;
  padding: 2.2rem 1.5rem 5rem;
}

/* ── PIPELINE ── */
.pipeline {
  display: none;
  align-items: center;
  gap: .3rem;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: .9rem 1.3rem;
  margin-bottom: 1.4rem;
  flex-wrap: wrap;
  gap: .5rem;
}
.pipeline.show { display: flex; animation: fadeUp .3s ease; }

.pipe-step {
  display: flex;
  align-items: center;
  gap: .4rem;
  font-size: .78rem;
  font-weight: 500;
  color: var(--muted);
  padding: .3rem .7rem;
  border-radius: 100px;
  transition: all .2s;
}
.pipe-step.active { background: var(--red-bg); color: var(--red); }
.pipe-step.done   { background: var(--green-bg); color: var(--green); }

.pipe-arrow { color: var(--border); font-size: .8rem; }
.pipe-icon  { font-size: .9rem; }

/* ── ZONE CARD ── */
.zone-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  margin-bottom: 1.4rem;
  animation: fadeUp .3s ease;
}

.zone-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 1.1rem 1.4rem;
  background: var(--ink);
  gap: 1rem;
  flex-wrap: wrap;
}

.zone-left { display: flex; align-items: center; gap: .8rem; }

.zone-badge {
  background: var(--accent);
  color: white;
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  padding: .4rem .9rem;
  border-radius: 8px;
  letter-spacing: -.02em;
  flex-shrink: 0;
}

.zone-name {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .92rem;
  color: #f5f2ec;
}
.zone-commune {
  font-size: .75rem;
  color: rgba(245,242,236,.45);
  margin-top: .15rem;
}

.zone-right { display: flex; flex-direction: column; align-items: flex-end; gap: .5rem; }

.zone-tags { display: flex; gap: .4rem; flex-wrap: wrap; justify-content: flex-end; }

.ztag {
  font-size: .65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
  padding: .18rem .55rem;
  border-radius: 4px;
  background: rgba(245,242,236,.1);
  color: rgba(245,242,236,.55);
  border: 1px solid rgba(245,242,236,.1);
}

.gpu-btn {
  font-size: .72rem;
  font-weight: 500;
  color: rgba(245,242,236,.5);
  text-decoration: none;
  transition: color .15s;
}
.gpu-btn:hover { color: #f5f2ec; }

.zone-rules {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--border);
}

.rule-cell {
  padding: .85rem 1rem;
  text-align: center;
  border-right: 1px solid var(--border);
}
.rule-cell:last-child { border-right: none; }

.rule-val {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.25rem;
  color: var(--accent);
  line-height: 1;
  margin-bottom: .18rem;
}
.rule-key {
  font-size: .67rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--muted);
}
.rule-note {
  font-size: .67rem;
  color: var(--muted);
  margin-top: .1rem;
  font-weight: 300;
}

.zone-footer {
  padding: .6rem 1.4rem;
  font-size: .72rem;
  color: var(--muted);
  background: var(--warm);
  border-top: 1px solid var(--border);
}
.zone-footer a { color: var(--blue); text-decoration: none; font-weight: 500; }
.zone-footer a:hover { text-decoration: underline; }

/* ── QA SECTION ── */
.qa-section { animation: fadeUp .3s ease; }

.qa-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .75rem;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--muted);
  margin-bottom: .75rem;
}

.quick-chips {
  display: flex;
  flex-wrap: wrap;
  gap: .45rem;
  margin-bottom: 1.4rem;
}

.q-chip {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--ink);
  font-size: .82rem;
  padding: .48rem 1rem;
  border-radius: 100px;
  cursor: pointer;
  transition: all .14s;
  font-family: 'Epilogue', sans-serif;
}
.q-chip:hover { border-color: var(--accent); color: var(--accent); background: var(--red-bg); }

.qa-divider {
  height: 1px;
  background: var(--border);
  margin: 1.4rem 0;
}

.free-bar {
  display: flex;
  gap: .5rem;
  align-items: center;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: .55rem .55rem .55rem 1rem;
  margin-bottom: 1.3rem;
  transition: border-color .15s, box-shadow .15s;
}
.free-bar:focus-within {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(192,56,26,.07);
}

.free-input {
  flex: 1;
  border: none;
  outline: none;
  font-family: 'Epilogue', sans-serif;
  font-size: .91rem;
  background: none;
  color: var(--ink);
}
.free-input::placeholder { color: var(--muted); }

.free-btn {
  background: var(--ink);
  color: #f5f2ec;
  border: none;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .79rem;
  padding: .58rem 1.2rem;
  border-radius: 9px;
  cursor: pointer;
  transition: background .15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.free-btn:hover:not(:disabled) { background: #2a2820; }
.free-btn:disabled { background: var(--border); color: var(--muted); cursor: not-allowed; }

/* ── ANSWERS ── */
.answers { display: flex; flex-direction: column; gap: 1rem; }

.answer-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  animation: fadeUp .28s ease;
}

.answer-top {
  display: flex;
  align-items: flex-start;
  gap: .9rem;
  padding: 1rem 1.2rem;
  border-bottom: 1px solid var(--border);
}

.verdict {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: .72rem;
  text-transform: uppercase;
  letter-spacing: .05em;
  padding: .32rem .85rem;
  border-radius: 100px;
  flex-shrink: 0;
  margin-top: .05rem;
}
.v-oui  { background: var(--green-bg); color: var(--green); border: 1px solid rgba(26,92,58,.14); }
.v-non  { background: var(--red-bg);   color: var(--red);   border: 1px solid rgba(192,56,26,.14); }
.v-cond { background: var(--amber-bg); color: var(--amber); border: 1px solid rgba(154,98,0,.14); }
.v-info { background: var(--blue-bg);  color: var(--blue);  border: 1px solid rgba(30,74,138,.14); }

.answer-q-text {
  font-size: .84rem;
  font-weight: 500;
  line-height: 1.4;
  flex: 1;
}
.answer-q-meta { font-size: .71rem; color: var(--muted); margin-top: .2rem; font-weight: 300; }

.answer-body {
  padding: 1.1rem 1.2rem;
  font-size: .87rem;
  line-height: 1.8;
  font-weight: 300;
}

.answer-resume {
  margin-bottom: .75rem;
  font-weight: 400;
  font-size: .9rem;
  line-height: 1.65;
}

.cond-line {
  display: flex;
  align-items: flex-start;
  gap: .55rem;
  padding: .5rem .75rem;
  border-radius: 7px;
  margin: .3rem 0;
  font-size: .83rem;
  line-height: 1.5;
}
.cond-ok    { background: var(--green-bg); }
.cond-alert { background: var(--red-bg); }
.cond-info  { background: var(--blue-bg); }
.cond-warn  { background: var(--amber-bg); }
.cond-icon  { flex-shrink: 0; margin-top: .05rem; }

.regles-title, .etapes-title, .couts-title {
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--muted);
  margin: .9rem 0 .4rem;
}

.regle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .42rem .75rem;
  background: var(--warm);
  border-radius: 6px;
  margin: .25rem 0;
  gap: .5rem;
}
.regle-label { font-size: .81rem; font-weight: 500; }
.regle-val   { font-size: .81rem; font-weight: 700; color: var(--accent); }
.regle-art   { font-size: .68rem; color: var(--muted); }

.etape-row {
  display: flex;
  gap: .55rem;
  align-items: flex-start;
  padding: .28rem 0;
}
.etape-num {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  color: var(--accent);
  font-size: .83rem;
  min-width: 18px;
  flex-shrink: 0;
}
.etape-text { font-size: .82rem; font-weight: 300; }

.couts-box {
  background: var(--amber-bg);
  border: 1px solid rgba(154,98,0,.15);
  border-radius: 8px;
  padding: .75rem 1rem;
  margin: .4rem 0;
}
.couts-amount { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; color: var(--amber); }
.couts-detail { font-size: .78rem; color: var(--amber); margin-top: .15rem; font-weight: 300; }

.answer-disclaimer {
  font-size: .73rem;
  color: var(--muted);
  font-style: italic;
  margin-top: .8rem;
  padding-top: .6rem;
  border-top: 1px solid var(--border);
  font-weight: 300;
}

.answer-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .65rem 1.2rem;
  background: var(--warm);
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
  gap: .5rem;
}

.answer-source {
  font-size: .7rem;
  color: var(--muted);
}
.answer-source a { color: var(--blue); text-decoration: none; font-weight: 500; }

.answer-btns { display: flex; gap: .4rem; }

.ans-btn {
  background: white;
  border: 1px solid var(--border);
  font-size: .71rem;
  font-weight: 500;
  padding: .28rem .7rem;
  border-radius: 7px;
  cursor: pointer;
  font-family: 'Epilogue', sans-serif;
  transition: all .12s;
}
.ans-btn:hover { border-color: var(--ink); }

/* ── SHIMMER ── */
.shimmer {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 1.3rem;
  display: flex;
  flex-direction: column;
  gap: .65rem;
}
.sh {
  border-radius: 5px;
  background: linear-gradient(90deg, var(--warm) 25%, var(--border) 50%, var(--warm) 75%);
  background-size: 300% 100%;
  animation: sh 1.5s infinite;
}
@keyframes sh { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

/* ── HOW IT WORKS ── */
.how { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
.how-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .75rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--muted);
  margin-bottom: 1.1rem;
  text-align: center;
}
.how-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.how-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 1.2rem 1rem;
  text-align: center;
}
.how-num {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.6rem;
  color: var(--border);
  line-height: 1;
  margin-bottom: .3rem;
}
.how-icon { font-size: 1.3rem; margin-bottom: .45rem; display: block; }
.how-card h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: .8rem; margin-bottom: .28rem; }
.how-card p { font-size: .73rem; color: var(--muted); line-height: 1.5; font-weight: 300; }

/* ── UTILS ── */
.hidden { display: none !important; }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

@media (max-width: 680px) {
  .how-grid   { grid-template-columns: 1fr 1fr; }
  .zone-rules { grid-template-columns: 1fr 1fr; }
  .hero h1    { font-size: 1.7rem; }
  .search-row { flex-wrap: wrap; }
}
